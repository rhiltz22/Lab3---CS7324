# visualize performance

import matplotlib.pyplot as plt

for solver in solvers:
    acc = [r[2] for r in results if r[0] == solver]
    plt.plot(C_values, acc, marker='o', label=solver)

plt.xscale('log')
plt.xlabel("Regularization Strength (C)")
